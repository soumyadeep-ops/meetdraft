{
  "version": 2,
  "buildCommand": "node scripts/init-db.js",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/public/admin.html"
    },
    {
      "source": "/join/:token",
      "destination": "/api/join/[token]"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    }
  ]
}